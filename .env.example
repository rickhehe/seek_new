# Seek Job Search Extractor Configuration

# URL Construction - Generate multiple search URLs from combinations
# Job roles to search for (comma-separated, URL-friendly format)
# Example: "Data-Engineer,Senior-Data-Engineer,Lead-Data-Engineer"
WHAT=Data-Engineer,ELT-Developer,SQL-Developer

# Locations to search in (comma-separated, URL-friendly format)
# Example: "All-Australia,Sydney-NSW,Melbourne-VIC"
WHERE=All-Australia,All-New-Zealand
# Salary ranges to search (comma-separated, format: min-max)
# Example: "120000-200000,150000-250000"
SALARY_RANGE=120000-200000

# Note: The app will generate URLs for all combinations of WHAT x WHERE x SALARY_RANGE
# Example: 2 roles x 3 locations x 2 salary ranges = 12 search URLs

# PostgreSQL Database settings
DB_PASSWORD="your_postgres_password_here"

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TG_API_KEY="your_telegram_bot_token_here"

# Get your chat ID by messaging @userinfobot on Telegram
TG_CHAT_ID=your_telegram_chat_id_here
