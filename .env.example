# Seek Job Search Extractor Configuration

# Your Seek search URL with filters (role, location, salary, date range, etc.)
# Get this by:
# 1. Go to seek.com.au
# 2. Search for jobs with your desired filters
# 3. Copy the URL from your browser

# Example filters:
#   daterange=2           - Last 2 days (1=24hrs, 2=3days, 3=7days, etc.)
#   salaryrange=120000-200000 - Salary between $120k-$200k
#   salarytype=annual     - Annual salary
#   worktype=244          - Contract roles
#   remoteoptions=3       - Remote work

SEARCH_URL="https://www.seek.com.au/Data-Engineer-jobs/in-All-Australia?daterange=2&salaryrange=120000-200000&salarytype=annual"

# PostgreSQL Database settings
DB_PASSWORD="your_postgres_password_here"

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TG_API_KEY="your_telegram_bot_token_here"

# Get your chat ID by messaging @userinfobot on Telegram
TG_CHAT_ID="your_telegram_chat_id_here"
